{
  "$schema": "https://bldgtyp.github.io/branding/tokens/schema.json",
  "meta": {
    "name": "BLDGTYP Design System",
    "version": "1.1.0",
    "updated": "2026-04-24"
  },

  "color": {
    "accent": {
      "base":   { "value": "#3E93AE", "description": "Primary steel blue accent — links, labels, borders, CTAs" },
      "light":  { "value": "#d6ebf1", "description": "Accent tint — hover states, subtle backgrounds" },
      "dark":   { "value": "#2d6b80", "description": "Accent shade — text on light backgrounds" }
    },
    "highlight": {
      "base":   { "value": "#E23489", "description": "Magenta — emphasis, hover borders, highlighted text" },
      "light":  { "value": "#fce8f1", "description": "Highlight tint" },
      "dark":   { "value": "#C42977", "description": "Highlight shade — text on light backgrounds" },
      "darker": { "value": "#931d57", "description": "Highlight deeper shade" }
    },
    "light": {
      "bg-page":        { "value": "#ffffff" },
      "bg-card":        { "value": "#ffffff" },
      "bg-elev":        { "value": "#fafafa" },
      "bg-section-alt": { "value": "#F8F9FA" },
      "bg-stats":       { "value": "#111111" },
      "text-primary":   { "value": "#111111" },
      "text-secondary": { "value": "#6b7280" },
      "text-muted":     { "value": "#9ca3af" },
      "border-subtle":  { "value": "#e5e7eb" },
      "border-card":    { "value": "#e5e7eb" },
      "border-strong":  { "value": "#c9cbd0" }
    },
    "dark": {
      "bg-page":        { "value": "#0C0C0C" },
      "bg-card":        { "value": "#151515" },
      "bg-elev":        { "value": "#1a1a1a" },
      "bg-section-alt": { "value": "#111111" },
      "bg-stats":       { "value": "#060606" },
      "text-primary":   { "value": "#ffffff" },
      "text-secondary": { "value": "#9ca3af" },
      "text-muted":     { "value": "#6b7280" },
      "border-subtle":  { "value": "#2a2a2a" },
      "border-card":    { "value": "#2a2a2a" },
      "border-strong":  { "value": "#3a3a3a" }
    }
  },

  "typography": {
    "font-primary": {
      "family": "Outfit",
      "source": "https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700&display=swap",
      "weights": {
        "thin":      200,
        "light":     300,
        "regular":   400,
        "medium":    500,
        "semibold":  600,
        "bold":      700
      }
    },
    "font-mono": {
      "family": "JetBrains Mono",
      "source": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400&display=swap",
      "weights": {
        "light":   300,
        "regular": 400
      }
    },
    "scale": {
      "hero-title":     { "family": "primary", "weight": 600, "size": "clamp(3rem, 6vw, 5.5rem)", "line-height": 1.15, "letter-spacing": "-0.02em" },
      "hero-title-2":   { "family": "primary", "weight": 500, "size": "clamp(52px, 7vw, 96px)", "line-height": 1.0, "letter-spacing": "-0.03em", "note": "Two-line hero with <em> highlight" },
      "section-heading":{ "family": "primary", "weight": 600, "size": "42px",   "line-height": 1.15, "letter-spacing": "-0.015em" },
      "card-title":     { "family": "primary", "weight": 600, "size": "16px",   "line-height": 1.4,  "letter-spacing": "0.1em", "transform": "uppercase" },
      "card-subtitle":  { "family": "primary", "weight": 500, "size": "20px",   "line-height": 1.4 },
      "doc-card-name":  { "family": "primary", "weight": 600, "size": "30px",   "line-height": 1.05, "letter-spacing": "-0.015em" },
      "body":           { "family": "primary", "weight": 300, "size": "16px",   "line-height": 1.7 },
      "body-large":     { "family": "primary", "weight": 300, "size": "17px",   "line-height": 1.8 },
      "hero-subtitle":  { "family": "primary", "weight": 300, "size": "22px",   "line-height": 1.6 },
      "hero-sub":       { "family": "mono",    "weight": 300, "size": "14.5px", "line-height": 1.55, "note": "// subtitle lines" },
      "nav-brand":      { "family": "primary", "weight": 500, "size": "14px",   "letter-spacing": "0.3em", "transform": "uppercase" },
      "section-label":  { "family": "mono",    "weight": 300, "size": "12px",   "letter-spacing": "0.15em", "transform": "uppercase" },
      "hero-label":     { "family": "mono",    "weight": 300, "size": "14px",   "letter-spacing": "0.12em", "transform": "uppercase" },
      "nav-link":       { "family": "mono",    "weight": 300, "size": "11px",   "letter-spacing": "0.05em", "transform": "uppercase" },
      "nav-trigger":    { "family": "mono",    "weight": 400, "size": "12.5px", "letter-spacing": "0.04em" },
      "sidebar-label":  { "family": "mono",    "weight": 300, "size": "10.5px", "letter-spacing": "0.18em", "transform": "uppercase" },
      "callout-title":  { "family": "mono",    "weight": 400, "size": "10.5px", "letter-spacing": "0.16em", "transform": "uppercase" },
      "button":         { "family": "mono",    "weight": 400, "size": "13px",   "letter-spacing": "0.1em",  "transform": "uppercase" },
      "search-btn":     { "family": "mono",    "weight": 300, "size": "12px" },
      "meta":           { "family": "mono",    "weight": 300, "size": "13px",   "letter-spacing": "0.05em", "transform": "uppercase" },
      "stat-number":    { "family": "primary", "weight": 600, "size": "48px",   "line-height": 1.1 },
      "stat-label":     { "family": "mono",    "weight": 300, "size": "12px",   "letter-spacing": "0.08em", "transform": "uppercase" }
    }
  },

  "motion": {
    "transition-base": "0.3s ease",
    "ease": "cubic-bezier(.2,.6,.2,1)"
  },

  "spacing": {
    "section-padding-y": "120px",
    "section-padding-x": "40px",
    "max-content-width": "1100px",
    "card-padding":      "40px 32px",
    "card-gap":          "32px",
    "button-padding":    "16px 42px",
    "header-height":     "64px"
  },

  "components": {
    "source": "https://bldgtyp.github.io/branding/tokens/components.css",
    "classes": {
      "btn-primary":          { "description": "Primary CTA button — accent background, white text" },
      "btn-ghost":            { "description": "Secondary button — transparent with subtle border" },
      "link":                 { "description": "Inline link — highlight color, dotted underline" },
      "icon-btn":             { "description": "32px square icon button — SVG icons, subtle border" },
      "nav-icons":            { "description": "Flex container for grouping icon buttons in nav" },
      "service-card":         { "description": "Card with accent bottom border, highlight top on hover" },
      "service-card__title":  { "description": "Card title — uppercase, accent colored" },
      "service-card__subtitle": { "description": "Card subtitle — medium weight" },
      "service-card__body":   { "description": "Card body text" },
      "stats-bar":            { "description": "Always-dark stats grid container" },
      "stats-bar__number":    { "description": "Large stat number — accent colored" },
      "stats-bar__label":     { "description": "Stat label — mono, uppercase, muted" },
      "section-label":        { "description": "Numbered section label — mono, uppercase, accent" },
      "graph-paper":          { "description": "Standard graph paper background (20px/100px grid)" },
      "graph-paper--medium":  { "description": "Medium density graph paper (12px/60px grid)" },
      "graph-paper--fine":    { "description": "Fine density graph paper (6px/30px grid)" },
      "graph-paper--hex":         { "description": "Hexagon graph paper background (r=20 honeycomb)" },
      "graph-paper--hex-medium":  { "description": "Medium density hexagon graph paper (r=12 honeycomb)" },
      "graph-paper--hex-fine":    { "description": "Fine density hexagon graph paper (r=7 honeycomb)" },
      "theme-toggle":         { "description": "32px square theme switch button" },
      "hero-title":           { "description": "Two-line hero title — second line via <em> in highlight color" },
      "hero-sub":             { "description": "Subtitle with // prefix lines — mono, muted" },
      "site-header":          { "description": "Sticky navbar with backdrop blur" },
      "site-header__logo":    { "description": "Folder-nav logo with / separator" },
      "nav-primary":          { "description": "Primary nav container with dropdown groups" },
      "nav-group":            { "description": "Nav dropdown group — trigger + dropdown panel" },
      "nav-hamburger":        { "description": "Mobile hamburger button (hidden >900px)" },
      "search-btn":           { "description": "Search trigger button with keyboard shortcut badge" },
      "doc-card":             { "description": "Documentation card — animated top border, multi-section layout" },
      "doc-card__idx":        { "description": "Card index row with number and dash separator" },
      "doc-card__tag":        { "description": "Card category tag — mono, uppercase, accent" },
      "doc-card__name":       { "description": "Card title — 30px semibold" },
      "doc-card__desc":       { "description": "Card description text" },
      "doc-card__footer":     { "description": "Card footer with dashed border and CTA arrow" },
      "sidebar":              { "description": "260px sidebar nav container" },
      "sidebar__label":       { "description": "Sidebar section divider with leading dash" },
      "nav-tree":             { "description": "Collapsible nav tree with chevrons and dashed child borders" },
      "callout":              { "description": "Callout block base — left accent bar, gradient bg" },
      "callout--note":        { "description": "Note callout — accent color gradient" },
      "callout--warning":     { "description": "Warning callout — highlight color gradient" },
      "site-footer":          { "description": "Mono footer bar — left nav items, right URL + version badge" },
      "site-footer__left":    { "description": "Left-aligned footer items with · separators" },
      "site-footer__right":   { "description": "Right-aligned footer with site URL and version badge" },
      "version-badge":        { "description": "Bordered version tag in footer" },
      "type-hero":            { "description": "Hero title typography" },
      "type-heading":         { "description": "Section heading typography" },
      "type-subheading":      { "description": "Subheading typography" },
      "type-body":            { "description": "Standard body text" },
      "type-body-lg":         { "description": "Large body text (17px)" },
      "type-mono-label":      { "description": "Mono uppercase label — accent colored" },
      "type-mono-nav":        { "description": "Mono nav link with hover state" }
    }
  },

  "accessibility": {
    "notes": [
      "Accent-dark #2d6b80 on white (#ffffff): 5.36:1 — passes AA at all text sizes",
      "Accent #3E93AE on dark (#0C0C0C): 5.08:1 — passes AA at all text sizes",
      "Highlight-dark #C42977 on white (#ffffff): 5.15:1 — passes AA at all text sizes",
      "Highlight #E23489 on dark (#0C0C0C): 4.89:1 — passes AA at all text sizes",
      "All body text combinations (text-primary on bg-page) pass WCAG AAA (7:1+) in both themes"
    ]
  }
}
